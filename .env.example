# =============================================================================
# AnswerLoops — Self-Host Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# See docs/ENV-VARS.md for full descriptions and setup instructions.
# =============================================================================


# -----------------------------------------------------------------------------
# CORE (required)
# -----------------------------------------------------------------------------

# Postgres connection string
# Docker local: postgresql://community:community@localhost:5432/community
# Production: use your Neon / Supabase / RDS connection string
DATABASE_URL=

# Auth.js session secret — any random string 32+ chars
# Generate: openssl rand -base64 32
AUTH_SECRET=

# AES-256-GCM key for encrypting bot tokens and API keys at rest
# Generate: openssl rand -hex 32  (must be exactly 64 hex chars)
ENCRYPTION_KEY=


# -----------------------------------------------------------------------------
# OAUTH — sign in with (at least one required)
# -----------------------------------------------------------------------------

# GitHub OAuth App — https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Discord OAuth App — https://discord.com/developers/applications
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=


# -----------------------------------------------------------------------------
# DISCORD BOT
# -----------------------------------------------------------------------------

# Bot token — Discord Developer Portal > Bot tab
DISCORD_TOKEN=

# Comma-separated channel IDs the bot listens in
DISCORD_CHANNEL_IDS=

# Shared secret between the bot and the Next.js app (any random string)
BOT_SECRET=

# URL the bot POSTs inbound messages to (your app's public or local URL)
BOT_TARGET_URL=http://localhost:3000

# Application ID — Discord Developer Portal > General Information
# Required to register /ask and /summarize slash commands
DISCORD_APPLICATION_ID=

# Guild ID — scope slash commands to one server for instant testing
# Omit (or leave blank) to register global commands (up to 1 hr to propagate)
DISCORD_GUILD_ID=


# -----------------------------------------------------------------------------
# AI PROVIDERS
# Org-level overrides are stored encrypted in the DB via Settings > AI Model.
# These are the platform-level fallback keys used before any org configures one.
# -----------------------------------------------------------------------------

# OpenAI (default)
OPENAI_API_KEY=

# Anthropic — Claude models
ANTHROPIC_API_KEY=

# Google — Gemini models
GOOGLE_GENERATIVE_AI_API_KEY=

# Groq — Llama / Mixtral
GROQ_API_KEY=

# Mistral
MISTRAL_API_KEY=


# -----------------------------------------------------------------------------
# STRIPE BILLING (optional — required only if enabling paid plans)
# -----------------------------------------------------------------------------

# Dashboard > Developers > API keys
STRIPE_SECRET_KEY=

# Dashboard > Webhooks > your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=

# Price IDs from Dashboard > Products (create one product per plan)
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_ENTERPRISE=


# -----------------------------------------------------------------------------
# EMAIL — Resend (optional)
# https://resend.com
# -----------------------------------------------------------------------------

RESEND_API_KEY=
RESEND_FROM=notifications@yourdomain.com

# Public base URL used for links in outbound emails
AUTH_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# GITHUB APP (optional — enables source-code aware answers)
# https://github.com/settings/apps
# -----------------------------------------------------------------------------

GITHUB_APP_ID=

# Base64-encoded PEM private key
# Encode: base64 -i your-app.private-key.pem | tr -d '\n'
GITHUB_APP_PRIVATE_KEY=

GITHUB_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# WEB PUSH NOTIFICATIONS (optional — browser push alerts)
# Generate keys: npx web-push generate-vapid-keys
# -----------------------------------------------------------------------------

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com


# -----------------------------------------------------------------------------
# URL INGEST — Firecrawl (optional — required for Settings > KB > Ingest URL)
# https://firecrawl.dev
# -----------------------------------------------------------------------------

FIRECRAWL_API_KEY=

# Only needed if running a self-hosted Firecrawl instance
# FIRECRAWL_API_URL=


# -----------------------------------------------------------------------------
# DEVELOPMENT / TESTING
# -----------------------------------------------------------------------------

# Set to 1 to bypass all external API calls (Discord, Slack, Resend, Stripe)
# Use in CI or local dev when you don't have live credentials
# MOCK_EXTERNALS=1
