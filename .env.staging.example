# Staging environment variables
# Copy to .env.staging and fill in values.
# DATABASE_URL is set by docker-compose.staging.yml — do not set it here.

# ── Required ─────────────────────────────────────────────────────────────────

AUTH_URL=http://localhost:3001
AUTH_SECRET=<run: openssl rand -hex 32>
ENCRYPTION_KEY=<run: openssl rand -hex 32>

# ── OAuth (at least one) ──────────────────────────────────────────────────────
# Use separate staging OAuth apps so staging callbacks don't pollute prod apps.
# GitHub: github.com/settings/developers → callback: http://localhost:3001/api/auth/callback/github
# Discord: callback: http://localhost:3001/api/auth/callback/discord
# Google: callback: http://localhost:3001/api/auth/callback/google

AUTH_GITHUB_ID=<your-staging-github-client-id>
AUTH_GITHUB_SECRET=<your-staging-github-client-secret>

# AUTH_DISCORD_ID=<your-staging-discord-client-id>
# AUTH_DISCORD_SECRET=<your-staging-discord-client-secret>
# AUTH_GOOGLE_ID=<your-staging-google-client-id>
# AUTH_GOOGLE_SECRET=<your-staging-google-client-secret>

# ── AI provider (at least one recommended) ───────────────────────────────────
# Reuse prod keys or create separate staging keys for cost tracking.

OPENAI_API_KEY=<your-openai-api-key>
# ANTHROPIC_API_KEY=<your-anthropic-api-key>
# GOOGLE_GENERATIVE_AI_API_KEY=<your-google-ai-api-key>
# GROQ_API_KEY=<your-groq-api-key>
# MISTRAL_API_KEY=<your-mistral-api-key>

# ── Discord bot (optional) ────────────────────────────────────────────────────
# Use a separate Discord application for staging so the staging bot doesn't
# post into your real community server.

# DISCORD_TOKEN=<your-staging-bot-token>
# DISCORD_CLIENT_ID=<your-staging-discord-app-client-id>
# DISCORD_CLIENT_SECRET=<your-staging-discord-app-client-secret>
# DISCORD_APPLICATION_ID=<your-staging-discord-app-client-id>
# BOT_SECRET=<run: openssl rand -hex 32>

# ── Slack (optional) ─────────────────────────────────────────────────────────
# SLACK_CLIENT_ID=<your-staging-slack-client-id>
# SLACK_CLIENT_SECRET=<your-staging-slack-client-secret>
# SLACK_SIGNING_SECRET=<your-staging-slack-signing-secret>
# SLACK_POLL_INTERVAL_SECONDS=60

# ── GitHub App (optional) ────────────────────────────────────────────────────
# GITHUB_APP_ID=<your-staging-github-app-id>
# GITHUB_APP_PRIVATE_KEY=<base64-encoded-pem>
# GITHUB_WEBHOOK_SECRET=<run: openssl rand -hex 32>
# GITHUB_APP_SLUG=<your-staging-github-app-slug>

# ── Telegram (optional) ──────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=<your-staging-telegram-bot-token>

# ── Resend email (optional) ──────────────────────────────────────────────────
# RESEND_API_KEY=<your-resend-api-key>
# RESEND_FROM=<staging@yourdomain.com>

# ── Firecrawl (optional) ─────────────────────────────────────────────────────
# FIRECRAWL_API_KEY=<your-firecrawl-api-key>

# ── Stripe (optional) ────────────────────────────────────────────────────────
# Use Stripe test mode keys for staging.
# STRIPE_SECRET_KEY=<sk_test_...>
# STRIPE_WEBHOOK_SECRET=<whsec_...>
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<pk_test_...>
# STRIPE_PRICE_PRO=<price_...>
# STRIPE_PRICE_SCALE=<price_...>
# STRIPE_PRICE_ENTERPRISE=<price_...>

# ── Web push (optional) ──────────────────────────────────────────────────────
# VAPID_PUBLIC_KEY=<your-vapid-public-key>
# VAPID_PRIVATE_KEY=<your-vapid-private-key>
# VAPID_EMAIL=mailto:<you@yourdomain.com>

# ── Access control (optional) ────────────────────────────────────────────────
# Restrict staging to specific emails while testing.
# ALLOWED_EMAILS=you@example.com
