{
  "name": "community-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "bot": "tsx watch bot/index.ts",
    "bot:start": "tsx bot/index.ts",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm bot\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:typecheck": "tsc --noEmit -p e2e/tsconfig.json",
    "test:e2e:ui": "playwright test --ui",
    "test:server": "next start -p 3100"
  },
  "engines": {
    "node": ">=20.9"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/groq": "^3.0.42",
    "@ai-sdk/mistral": "^3.0.40",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/react": "^3.0.209",
    "@mendable/firecrawl-js": "^4.28.1",
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "ai": "^6.0.153",
    "csv-parse": "^7.0.0",
    "discord.js": "^14.26.2",
    "drizzle-orm": "^0.45.2",
    "mammoth": "^1.12.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "stripe": "^22.2.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
