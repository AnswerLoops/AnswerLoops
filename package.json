{
  "name": "community-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "bot": "tsx watch bot/index.ts",
    "bot:start": "tsx bot/index.ts",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm bot\"",
    "test:e2e": "playwright test",
    "test:e2e:typecheck": "tsc --noEmit -p e2e/tsconfig.json",
    "test:e2e:ui": "playwright test --ui",
    "test:server": "next start -p 3100"
  },
  "engines": {
    "node": ">=20.9"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/react": "^3.0.209",
    "@mendable/firecrawl-js": "^4.28.1",
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "ai": "^6.0.153",
    "better-sqlite3": "^12.8.0",
    "discord.js": "^14.26.2",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.2",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
